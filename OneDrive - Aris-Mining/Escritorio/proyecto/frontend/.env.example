# Base del API REST (coincide con Express: app.use('/api/users', ...)).
# Desarrollo con Vite (npm run dev en :3000): use /api para que el proxy reenvíe a :5000.
VITE_API_BASE_URL=/api

# Vista previa UPN para pestaña "Administrativo (AD)" — mismo dominio que AD_QUEUE_EMAIL_DOMAIN en backend/.env (sin @)
VITE_AD_UPN_SUFFIX=empresa.co

# Entra ID / Azure AD (SPA)
# Registre la misma URL de origen (p. ej. http://localhost:5173) como redirect URI SPA;
# se usa también tras cerrar sesión (logoutRedirect).
VITE_AZURE_TENANT_ID=YOUR_TENANT_ID
VITE_AZURE_CLIENT_ID=YOUR_CLIENT_ID

# Object ID del grupo permitido ("logi")
VITE_AZURE_LOGI_GROUP_ID=YOUR_LOGI_GROUP_OBJECT_ID

