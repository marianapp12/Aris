# Base del API REST (coincide con Express: app.use('/api/users', ...)).
# Desarrollo con Vite (npm run dev en :3000): use /api para que el proxy reenvíe a :5000.
VITE_API_BASE_URL=/api

# Entra ID / Azure AD (SPA)
# Registre la misma URL de origen (p. ej. http://localhost:5173) como redirect URI SPA;
# se usa también tras cerrar sesión (logoutRedirect).
VITE_AZURE_TENANT_ID=YOUR_TENANT_ID
VITE_AZURE_CLIENT_ID=YOUR_CLIENT_ID

# Object ID del grupo permitido ("logi")
VITE_AZURE_LOGI_GROUP_ID=YOUR_LOGI_GROUP_OBJECT_ID

# --- Plantillas Excel (SharePoint u otra URL) ---
# Pasos recomendados para que la plantilla con diseño NO dependa del .xlsx en public/:
# 1) Suba el Excel maquetado a una biblioteca de SharePoint (o Teams).
# 2) Obtenga el vínculo al archivo (debe empezar por https://).
# 3) Pegue ese vínculo abajo en la variable que corresponda (operativos y/o administrativos).
# 4) Guarde este archivo como frontend/.env y reinicie "npm run dev" (o vuelva a desplegar en producción).
# Tras abrir el enlace en el navegador, los usuarios deben usar Archivo → Guardar como → Descargar una
# copia (o Crear una copia) para trabajar en local y no alterar el original en SharePoint.
# Si deja las líneas comentadas o vacías, el botón "Descargar plantilla" usará public/plantilla-*.xlsx
#
# VITE_PLANTILLA_OPERARIOS_URL=https://suempresa.sharepoint.com/sites/.../plantilla-operarios.xlsx
# VITE_PLANTILLA_ADMINISTRATIVOS_URL=https://suempresa.sharepoint.com/sites/.../plantilla-administrativos.xlsx
