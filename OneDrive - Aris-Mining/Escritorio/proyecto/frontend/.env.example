# Base del API REST: debe incluir el prefijo /api (coincide con Express: app.use('/api/users', ...)).
# También válido: http://localhost:5000/api o, con proxy de Vite, /api
VITE_API_BASE_URL=http://localhost:5000/api

# Vista previa UPN para pestaña "Administrativo (AD)" — mismo dominio que AD_PS_EMAIL_DOMAIN en backend/.env (sin @)
VITE_AD_UPN_SUFFIX=empresa.co

# Entra ID / Azure AD (SPA)
VITE_AZURE_TENANT_ID=YOUR_TENANT_ID
VITE_AZURE_CLIENT_ID=YOUR_CLIENT_ID

# Object ID del grupo permitido ("logi")
VITE_AZURE_LOGI_GROUP_ID=YOUR_LOGI_GROUP_OBJECT_ID

