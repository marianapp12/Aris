# Azure AD / Microsoft 365 Configuration (usuarios operativos vía Graph)
# Comprobar en Azure Portal: permisos de aplicación User.ReadWrite.All (consentimiento admin),
# secreto vigente y que AZURE_TENANT_ID / AZURE_CLIENT_ID coincidan con el registro.
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Server Configuration
PORT=5000
NODE_ENV=development

# --- Usuarios administrativos: PowerShell + Invoke-Command (solo Windows) ---
# El backend debe ejecutarse en Windows con WinRM hacia AD_PS_COMPUTER_NAME.
# Scripts por defecto: backend/scripts/Create-AdAdministrativeUser.ps1 y Select-FirstAvailableAdSam.ps1

# Servidor donde se ejecuta New-ADUser (mismo que en Invoke-Command -ComputerName).
# Preferir FQDN del dominio. Si usa IP: ejecute en PowerShell (Admin):
#   Set-Item WSMan:\localhost\Client\TrustedHosts -Value '192.168.x.x' -Concatenate
# y defina AD_PS_WINRM_USER / AD_PS_WINRM_PASSWORD (cuenta de dominio con permisos en el DC).
AD_PS_COMPUTER_NAME=dc01.corp.local

# Opcional: credenciales explícitas para WinRM (casi obligatorio si AD_PS_COMPUTER_NAME es una IP)
# AD_PS_WINRM_USER=DOMINIO\usuario_servicio
# AD_PS_WINRM_PASSWORD=change-me

# DN de la OU destino (parámetro -Path de New-ADUser)
AD_PS_OU_PATH=OU=Administrativos,DC=corp,DC=local

# Dominio del UPN/correo (sin @; ej. empresa.co)
AD_PS_EMAIL_DOMAIN=empresa.co

AD_PS_COMPANY=MiEmpresa

# Raíz de carpeta de usuario (HomeDirectory = esta ruta + \sAMAccountName)
AD_PS_HOME_DIRECTORY_ROOT=E:\Usr

# Grupos AD separados por coma (Add-ADGroupMember)
AD_PS_GROUPS=Bloqueo_DLP,SSO-ARM_Internet_Estandar

# Credenciales para Connect-ExchangeOnline / Connect-MsolService (obligatorias si AD_PS_SKIP_CLOUD_STEPS=false)
AD_PS_EXO_USER=automation@empresa.co
AD_PS_EXO_PASSWORD=change-me

# true = no conecta a EXO/MSOL ni espera sincronización (solo AD remoto)
AD_PS_SKIP_CLOUD_STEPS=true

# Segundos de espera antes del bucle Get-MsolUser (si no skip cloud)
AD_PS_CLOUD_SLEEP_SECONDS=240

# Habilitar bloque MFA vía Set-MsolUser tras sincronización (requiere MSOnline)
# AD_PS_MFA_BLOCK_ENABLED=true

# Repadmin: true para ejecutar líneas siguientes (separadas por |||)
# AD_PS_REPADMIN_ENABLED=false
# AD_PS_REPADMIN_LINES=repadmin /replicate DC1 DC2 dc=corp,dc=local|||repadmin /replicate DC1 DC3 dc=corp,dc=local

# Ruta opcional a Generarpswd.ps1 (función Ramdom-Password / Random-Password). Si vacío, se genera contraseña en script.
# AD_PS_PASSWORD_SCRIPT_PATH=C:\scripts\Generarpswd.ps1

# Ruta opcional a powershell.exe si no está en PATH
# AD_PS_POWERSHELL_PATH=C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe

# Scripts personalizados (opcional)
# AD_PS_CREATE_SCRIPT_PATH=C:\ruta\Create-AdAdministrativeUser.ps1
# AD_PS_SELECT_SAM_SCRIPT_PATH=C:\ruta\Select-FirstAvailableAdSam.ps1

# Valores por defecto si el formulario no envía cédula / ciudad
# AD_PS_DEFAULT_EMPLOYEE_ID=
# AD_PS_DEFAULT_CITY=
