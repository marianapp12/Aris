# Azure AD / Microsoft 365 Configuration (usuarios operativos vía Graph)
# Comprobar en Azure Portal: permisos de aplicación User.ReadWrite.All (consentimiento admin),
# y para asignar operativos a grupos por sede: GroupMember.ReadWrite.All (consentimiento admin).
# secreto vigente y que AZURE_TENANT_ID / AZURE_CLIENT_ID coincidan con el registro.
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Dominio UPN para usuarios operativos creados vía Graph (misma lógica de candidatos que administrativos en cola AD).
# Si no se define, se usa el valor por defecto del código (solo desarrollo).
# OPERATIONAL_UPN_DOMAIN=contoso.onmicrosoft.com

# --- Grupos por sede (usuarios operativos) ---
# Tras crear el usuario en Graph se llama POST .../groups/{id}/members/$ref.
# Checklist si una sede falla y otra no (p. ej. Medellín sí, Segovia/Marmato no):
# 1) Nombres EXACTOS de variable (ASCII, sin tilde en el nombre): GROUP_MEDELLIN_ID, GROUP_SEGOVIA_ID, GROUP_MARMATO_ID, GROUP_BOGOTA_ID, GROUP_BUCARAMANGA_ID.
# 2) Cada valor = Object ID del grupo en Entra ID (Grupos > [grupo] > Id. de objeto). Mismo criterio para cada sede.
# 3) Sin comillas ni espacios alrededor del UUID (o use comillas dobles completas; el backend las quita). Sin pegar el nombre del grupo.
# 4) Grupo asignado (no solo membresía dinámica si Graph no permite agregar miembros).
# 5) GroupMember.ReadWrite.All (aplicación) + consentimiento de administrador en el registro de esta app.
# 6) Opcional: Group.Read.All (aplicación) para que la API lea el displayName del grupo y el front muestre el nombre (no solo "miembro agregado").
# 7) Reinicie Node tras editar .env. En logs: [SEDE] falta/UUID inválido; [GRAPH] error al agregar; la API puede devolver graphError en groupMemberships.
# Si falta GROUP_*_ID para una sede, el usuario se crea igual; solo verá advertencia [SEDE] en logs.
# GROUP_MEDELLIN_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# GROUP_SEGOVIA_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# GROUP_MARMATO_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# GROUP_BOGOTA_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# GROUP_BUCARAMANGA_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Grupos comunes (todos los operarios, además del grupo por sede). Tres Object ID separados por coma.
# Si un ID coincide con el de la sede, solo se llama una vez a Graph (deduplicado).
# OPERATIONAL_COMMON_GROUP_IDS=uuid1,uuid2,uuid3
# Opcional: nombres para la UI (mismo orden y número de segmentos que la línea anterior; sin comas dentro de cada nombre).
# Si Graph no devuelve displayName del grupo, se usan estas etiquetas en la pantalla de éxito.
# OPERATIONAL_COMMON_GROUP_DISPLAY_NAMES=Grupo General,Grupo Seguridad,Grupo Comunicaciones

# Server Configuration
PORT=5000
NODE_ENV=development

# --- Usuarios administrativos: cola SMB (JSON en carpeta compartida) ---
# El proceso Node debe ejecutarse en Windows (o con acceso SMB) con permiso de escritura en la UNC.
# Un script PowerShell en el servidor procesa pendiente-*.json (ver docs/server-scripts/).

# Ruta UNC o local donde se escriben los archivos pendiente-{uuid}.json
# El backend escanea pendiente-*.json aquí para evitar duplicar la misma cédula antes de que Graph la muestre.
AD_QUEUE_UNC=\\10.10.11.9\scripts\pending

# Carpeta resultados: resultado-{uuid}.json para polling (por defecto: hermana de pending, ej. \\srv\scripts\resultados).
# Si aún usa la ruta antigua bajo pending, defínala explícitamente:
# AD_QUEUE_RESULTS_UNC=\\10.10.11.9\scripts\pending\resultados

# Carpeta procesados: un JSON por cédula tras crear el usuario en AD (escribe Process-AdUserQueue.ps1).
# El backend la lee para bloquear duplicados antes de que Entra ID sincronice.
# Por defecto: hermano de "pending" → \\servidor\scripts\procesados si AD_QUEUE_UNC termina en \pending
# AD_QUEUE_PROCESSED_UNC=\\10.10.11.9\scripts\procesados
# Limpieza recomendada: el backend borra el JSON en procesados cuando Graph ya muestra esa cédula (employeeId).
# AD_PROCESSED_GRAPH_CLEANUP_ENABLED=true   (false o 0 para desactivar)
# AD_PROCESSED_GRAPH_SYNC_INTERVAL_MS=60000  (mínimo 5000)
# AD_PROCESSED_GRAPH_MAX_FILES_PER_CYCLE=50
# Opcional por tiempo (solo respaldo; 0 = sin caducidad por reloj):
# AD_QUEUE_PROCESSED_TTL_HOURS=0

# Dominio del UPN/correo (sin @), alineado con Azure AD Connect / AD
AD_QUEUE_EMAIL_DOMAIN=empresa.co

# Opcional: DN de OU incluido en el JSON como queueMetadata.ouDn (el script PS puede usar otro valor fijo)
# AD_QUEUE_OU_DN=OU=Administrativos,DC=corp,DC=local

# Opcional: nombre de empresa para el atributo Company en AD (campo empresa en el JSON)
# AD_QUEUE_COMPANY=Mi Empresa

# Versión del esquema del JSON (entero >= 1)
# AD_QUEUE_SCHEMA_VERSION=1

# Opcional y desaconsejado salvo política explícita: se envía en queueMetadata.initialPasswordFromQueue
# AD_QUEUE_INITIAL_PASSWORD=

# Prechequeo con Microsoft Graph antes de encolar (orden: Entra employeeId → procesados → pendiente → LDAP cédula → sAM en AD).
# La disponibilidad de sAMAccountName/UPN para administrativos se consulta en Active Directory vía LDAP (mismas variables AD_LDAP_*)
# cuando están las cuatro definidas; si no, Node propone solo el primer candidato y Process-AdUserQueue.ps1 elige el primero libre en AD.
# Si está en true, Node no llama a Graph: no valida cédula en M365 (no usar en producción).
# AD_QUEUE_REQUIRE_GRAPH_FOR_ADMIN=true rechaza encolado si además activa SKIP (fuerza Graph en administrativos).
# Los usuarios recién creados en AD pueden tardar minutos en aparecer en Graph (Azure AD Connect);
# para detectar cédulas duplicadas al instante use el bloque AD_LDAP_* abajo.
# AD_QUEUE_SKIP_GRAPH_PRECHECK=true
# AD_QUEUE_REQUIRE_GRAPH_FOR_ADMIN=true

# --- Opcional: prechequeo LDAP contra Active Directory ---
# Con las cuatro variables: (1) cédula en employeeID, (2) primer sAMAccountName libre con la misma secuencia de candidatos que operativos M365.
# Recomendado en producción para alinear Node con AD antes de escribir pendiente-*.json.
# Las cuatro variables deben estar definidas para activar LDAP; si falta alguna, se omite (el script PS sigue resolviendo colisiones de sAM).
# Si LDAP está definido pero falla bind/red/certificado, Node registra advertencia y sigue: primer candidato de sAM y sin bloqueo por employeeID vía LDAP
# (siguen Graph, procesados y pendiente). Corrija la conectividad al DC para recuperar el prechequeo estricto en AD.
# AD_LDAP_URL=ldap://dc01.corp.local:389
# AD_LDAP_URL=ldaps://dc01.corp.local:636
# AD_LDAP_BIND_DN=CN=servicio-colas,OU=ServiceAccounts,DC=corp,DC=local
# AD_LDAP_BIND_PASSWORD=
# AD_LDAP_SEARCH_BASE=DC=corp,DC=local
# Opcional: en laboratorio con certificado no confiable, AD_LDAP_TLS_REJECT_UNAUTHORIZED=false
# AD_LDAP_TIMEOUT_MS=10000
# AD_LDAP_CONNECT_TIMEOUT_MS=8000

# Compruebe en Azure AD Connect que el atributo employeeID de AD se sincroniza a "id. de empleado" (employeeId) en Entra ID;
# si no, Graph no verá la cédula aunque exista en AD.
